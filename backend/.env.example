# Servidor
PORT=3000
NODE_ENV=development

# PostgreSQL (dados estruturados: usuários, pontos de coleta, denúncias)
PG_HOST=localhost
PG_PORT=5432
PG_USER=edescarte_user
PG_PASSWORD=troque_esta_senha
PG_DATABASE=edescarte_db

# MongoDB (fotos de denúncias, logs, eventos)
MONGO_URI=mongodb://localhost:27017/edescarte_media

# JWT
JWT_SECRET=troque_esta_chave_secreta_super_segura
JWT_EXPIRES_IN=7d

# Google Maps API (geolocalização e geocoding)
GOOGLE_MAPS_API_KEY=sua_chave_google_maps_aqui

# E-mail (Nodemailer / SMTP - alertas de denúncia)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alertas@edescarte.org
SMTP_PASSWORD=senha_app_email

# SMS (Twilio - alertas)
TWILIO_ACCOUNT_SID=seu_account_sid
TWILIO_AUTH_TOKEN=seu_auth_token
TWILIO_PHONE_NUMBER=+5500000000000
